{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id, u.username, COUNT(p.id) AS post_count\n        FROM users u\n        LEFT JOIN posts p ON p.author_id = u.id\n        WHERE u.username = $1\n        GROUP BY u.id, u.username\n        ",
