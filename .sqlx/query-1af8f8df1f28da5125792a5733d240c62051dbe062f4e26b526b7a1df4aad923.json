{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT p.id, p.author_id, p.content, p.created_at, u.username AS author_username\n        FROM posts p\n        JOIN users u ON u.id = p.author_id\n        WHERE p.author_id = $1\n        ORDER BY p.created_at DESC, p.id DESC\n        ",
